# Server
PORT=3000
BASE_URL=https://your-server.example.com

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14405863762

# Slack
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_CHANNEL_ID=C0XXXXXXXXX
SLACK_BOT_USER_ID=U0XXXXXXXXX

# Optional: auto-reply message for first-time senders (leave empty to disable)
AUTO_REPLY_MESSAGE=Thank you for reaching out! Our support team has been notified and will respond shortly.

# Optional: skip signature validation during development
# SKIP_TWILIO_VALIDATION=true
# SKIP_SLACK_VALIDATION=true

# Optional: custom database path (defaults to ./data/messenger.db)
# DB_PATH=/path/to/messenger.db
